# Copy this file to ".env" and fill in real values. Do NOT commit ".env".

# Postgres connection used by the app at runtime (pooled connection recommended).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Direct (non-pooled) Postgres connection used by Prisma CLI for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# NextAuth: a strong random secret is REQUIRED in production.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# NextAuth: the canonical URL of the deployment (no trailing slash).
NEXTAUTH_URL="https://your-domain.com"
